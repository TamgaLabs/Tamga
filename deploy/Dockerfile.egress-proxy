FROM golang:1.26-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY backend/ ./backend/
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /egress-proxy ./backend/cmd/egress-proxy/

FROM alpine:3.21
RUN apk add --no-cache ca-certificates && \
    rm -rf /var/cache/apk/*
COPY --from=builder /egress-proxy /usr/local/bin/egress-proxy
EXPOSE 8888
CMD ["egress-proxy"]
