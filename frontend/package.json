{
  "name": "tamga-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:offline": "NEXT_PUBLIC_OFFLINE_MODE=true next dev",
    "build": "next build",
    "build:offline": "NEXT_PUBLIC_OFFLINE_MODE=true next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "test -x ./node_modules/.bin/vitest || { echo 'Frontend unit tests require Vitest (provided by FEAT-052); install declared dependencies first.' >&2; exit 2; }; exec ./node_modules/.bin/vitest run",
    "test:e2e": "test -f ./playwright.config.ts && test -x ./node_modules/.bin/playwright || { echo 'Browser E2E requires the Playwright dependency and config supplied by FEAT-053.' >&2; exit 2; }; test -n \"$E2E_BASE_URL\" && test -n \"$E2E_ADMIN_PASSWORD\" && test \"$E2E_OWNED_STACK\" = 1 || { echo 'Browser E2E requires E2E_BASE_URL, E2E_ADMIN_PASSWORD, and E2E_OWNED_STACK=1 for a CI-owned disposable Tamga stack.' >&2; exit 2; }; exec ./node_modules/.bin/playwright test"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.5",
