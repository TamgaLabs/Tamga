DOMAIN=localhost
ADMIN_PASSWORD=admin
JWT_SECRET=generate-a-random-64-char-string-here
CADDY_EMAIL=admin@example.com
CADDY_ADMIN_URL=http://caddy:2019
CADDY_AUTO_SSL=true
UI_DOMAIN=localhost
API_DOMAIN=api.localhost
DB_PATH=./data/tamga.db
DATA_DIR=./data
# HOST_DATA_DIR is the absolute host-side path to the data directory (mounted as ./data:/data in docker-compose.yml).
# When using docker-compose, it is automatically set via docker-compose.yml's environment override (${PWD}/data).
# Only needed if running the backend outside docker-compose; set to the absolute path of your data directory.
# HOST_DATA_DIR=/absolute/path/to/data
# SYSTEM_CODE_DIR is the container-side path to the Tamga source, used to expose the
# "Tamga (System)" codebase on the /code page. When using docker-compose, it is
# automatically set via docker-compose.yml's environment override (the repo root is
# bind-mounted read-only at /tamga-src). Only needed if running the backend outside
# docker-compose; set to the absolute path of your Tamga checkout.
# SYSTEM_CODE_DIR=/absolute/path/to/tamga/checkout
PORT=8080
